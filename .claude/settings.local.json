{
  "permissions": {
    "allow": [
      "Bash(./mvnw --version)",
      "Bash(java -version)",
      "Bash(curl -sL https://repo.maven.apache.org/maven2/org/apache/maven/wrapper/maven-wrapper-distribution/3.2.0/maven-wrapper-distribution-3.2.0-bin.zip -o /tmp/mvnw.zip)",
      "Bash(unzip -o /tmp/mvnw.zip -d /tmp/mvnw-extract)",
      "Bash(cp /tmp/mvnw-extract/apache-maven-wrapper-3.2.0/mvnw .)",
      "Bash(cp /tmp/mvnw-extract/apache-maven-wrapper-3.2.0/mvnw.cmd .)",
      "Bash(cp /tmp/mvnw-extract/apache-maven-wrapper-3.2.0/.mvn/wrapper/* .mvn/wrapper/)",
      "Bash(chmod:*)",
      "Bash(./mvnw spring-boot:run)",
      "Bash(git init:*)",
      "Bash(git add:*)",
      "Bash(gh auth:*)",
      "Bash(git rm:*)"
    ]
  }
}
